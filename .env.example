# Telegram
TELEGRAM_TOKEN=
BOT_DISPLAY_NAME=Esqueletops • Nova
OWNER_IDS=123456789
LOG_CHANNEL_ID=
BOT_API_URL=https://api.telegram.org
AUTO_CONFIGURE_BOT=true

# Execução: polling ou webhook
RUN_MODE=polling
POLLING_LOCK_ENABLED=true
POLLING_LOCK_TTL_SECONDS=45
POLLING_LOCK_RETRY_SECONDS=5
HOST=0.0.0.0
PORT=3000
WEBHOOK_URL=
WEBHOOK_SECRET=

# PostgreSQL e Redis (endereços internos do EasyPanel)
DATABASE_URL=postgresql://postgres:SENHA@postgres:5432/esqueletops
DATABASE_POOL_MAX=10
REDIS_URL=redis://default:SENHA@redis:6379/0
REDIS_REQUIRED=true
REDIS_PREFIX=esqueletops:nova

# Logs
LOG_LEVEL=info
LOG_HEARTBEAT_SECONDS=300
NODE_ENV=production
TZ=America/Sao_Paulo

# Downloads
YTDLP_BINARY=yt-dlp
GALLERYDL_BINARY=gallery-dl
GALLERYDL_ENABLED=true
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
YTDLP_COOKIES_B64=
YTDLP_PROXY=
MEDIA_ALLOWED_DOMAINS=
ALLOW_GENERIC_URLS=false
MAX_LINKS_PER_MESSAGE=3
MAX_MEDIA_ITEMS=10
MAX_UPLOAD_MB=49
MAX_AUTO_DURATION_SECONDS=180
MAX_FORCE_DURATION_SECONDS=1800
DOWNLOAD_CONCURRENCY=2
DOWNLOAD_COOLDOWN_SECONDS=8
DOWNLOAD_TIMEOUT_SECONDS=180
MEDIA_CACHE_TTL_SECONDS=604800
MEDIA_PROGRESS_MESSAGES=true
MEDIA_INCLUDE_SOURCE_LINK=true
MEDIA_SOURCE_BUTTON=true
DELETE_TEMP_FILES=true

# Tradução: google ou libretranslate
TRANSLATE_PROVIDER=google
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

# Clima (Open-Meteo não exige chave)
WEATHER_DEFAULT_LANGUAGE=pt
