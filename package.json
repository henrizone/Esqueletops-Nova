{
  "name": "esqueletops-nova",
  "version": "1.6.0",
  "private": true,
  "type": "module",
  "description": "Esqueletops • Nova — bot multifunções para Telegram em TypeScript",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
