    "ioredis": "^5.11.1",
    "nanoid": "^5.1.6",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "sanitize-filename": "^1.6.4",
    "sharp": "^0.35.3",
    "zod": "^4.4.3",
    "p-queue": "^9.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "pino-pretty": "^13.1.1",
